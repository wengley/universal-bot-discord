<%- include('header', { user: user, guild: null, activePage: 'servers', botAvatarUrl: botAvatarUrl }) %>

<div id="wrapper">
    <%- include('sidebar', { user: user, guild: null, activePage: 'servers', botAvatarUrl: botAvatarUrl }) %>

    <div id="content">
        <div class="main-content">
            <h1><i class="fas fa-server"></i> Selecione um Servidor</h1>
            <p>Servidores onde você é <strong>Dono</strong> ou tem permissão de <strong>Administrador</strong>.</p>

            <% if (showInviteAlert) { %>
                <div class="alert alert-danger">
                    ❌ Você cancelou a adição do Bot ao servidor ou não tem permissão.
                </div>
            <% } %>

            <div class="guild-list">
                <% guilds.forEach(guild => { %>
                    <%
                        const itemClass = guild.isInBot ? '' : 'denied';
                        const statusButtonClass = guild.isInBot ? 'btn-primary' : 'btn-denied';
                        const statusText = guild.isInBot ? 'Bot Presente' : 'BOT Ausente';
                    %>
                    <div class="guild-item <%= itemClass %>">
                        <div class="guild-item-main">
                            <img src="<%= guild.icon %>" alt="" class="guild-icon">
                            <div class="guild-details">
                                <div class="guild-name" title="<%= guild.name %>"><%= guild.name %></div>
                                <div class="guild-role-tag">Seu Cargo: <%= guild.userRole %></div>
                            </div>
                        </div>
                        <div class="guild-item-footer">
                            <span class="btn status-btn <%= statusButtonClass %>"><%= statusText %></span>
                            <% if (guild.isInBot) { %>
                                <a href="/dashboard/<%= guild.id %>" class="btn btn-primary btn-configure"><i class="fas fa-cog"></i> Configurar</a>
                            <% } else { %>
                                <a href="#" class="btn btn-denied btn-configure disabled-link">Indisponível</a>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
