<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Painel de Controle</title>
    <link href="/css/styles.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600;700&family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        /* Estilos específicos da Landing Page */
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background: radial-gradient(circle at 20% 20%, var(--accent-soft), transparent 45%), var(--bg);
        }
        .landing-container {
            text-align: center;
            background: var(--bg-elevated);
            border: 1px solid var(--border);
            padding: 50px;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow);
            max-width: 600px;
            width: 90%;
            transition: all 0.3s;
        }
        .landing-header {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-bottom: 20px;
        }
        .landing-header .bot-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            box-shadow: var(--shadow-glow);
        }
        .landing-container h1 {
            font-size: 2.2em;
            color: var(--text);
            margin: 0;
        }
        .landing-container p {
            font-size: 1.05em;
            color: var(--text-muted);
            margin-bottom: 30px;
        }
        .ping-status {
            font-size: 0.85em;
            color: var(--text-muted);
            margin-top: 22px;
        }
        .ping-status strong { color: var(--success); }
        .copyright {
            margin-top: 8px;
            font-size: 0.78em;
            color: var(--text-muted);
            opacity: .7;
        }
        .landing-container .btn-primary {
            padding: 15px 30px;
            font-size: 1em;
        }
    </style>
</head>
<body>
    <div class="landing-container">
        <div class="landing-header">
            <img src="<%= botAvatarUrl || '/img/default_bot_avatar.png' %>" alt="Bot Icon" class="bot-icon">
            <h1><%= title %></h1>
        </div>
        
        <p>
            O Painel de Controle completo para gerenciar seu servidor Discord. 
            Configurações de Boas-Vindas, AutoRole, Moderação e muito mais, tudo em um só lugar.
        </p>
        <a href="/login" class="btn btn-primary">
            Faça Login com Discord e acesse o Painel
        </a>
        <div class="ping-status">
            Status: Ping atual do Bot é de <strong><%= ping %>ms</strong>
        </div>
        <div class="copyright">
            © Universal Bot. Todos os direitos reservados.
        </div>
    </div>
    <script>
        if (localStorage.getItem('theme') === 'dark') {
            document.body.classList.add('dark-mode');
        } else {
            document.body.classList.remove('dark-mode'); 
        }
    </script>
</body>
</html>