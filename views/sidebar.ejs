<nav id="sidebar">
    <div class="sidebar-header">
        <img src="<%= botAvatarUrl %>" alt="Logo" class="bot-logo">
        <span>Universal<em>Bot</em></span>
    </div>

    <% if (guild) { %>
        <div class="nav-separator">CONFIG. <%= guild.name.toUpperCase() %></div>
        <a class="nav-link <%= activePage === 'settings' ? 'active' : '' %>" href="/dashboard/<%= guild.id %>"><i class="fas fa-cog"></i> Config. Geral</a>

        <div class="nav-separator">COMANDOS</div>
        <a class="nav-link <%= activePage === 'commands' ? 'active' : '' %>" href="/dashboard/<%= guild.id %>/commands"><i class="fas fa-terminal"></i> Comandos do Universal BOT</a>
        <a class="nav-link <%= activePage === 'prefixed-commands' ? 'active' : '' %>" href="/dashboard/<%= guild.id %>/prefixed-commands"><i class="fas fa-keyboard"></i> Comandos por Prefixo</a>
        <a class="nav-link <%= activePage === 'command-channels' ? 'active' : '' %>" href="/dashboard/<%= guild.id %>/command-channels"><i class="fas fa-hashtag"></i> Canais de Comandos</a>
        <a class="nav-link <%= activePage === 'custom-commands' ? 'active' : '' %>" href="/dashboard/<%= guild.id %>/custom-commands"><i class="fas fa-magic"></i> Comandos Personalizados</a>

        <div class="nav-separator">COMUNIDADE</div>
        <a class="nav-link <%= activePage === 'welcome' ? 'active' : '' %>" href="/dashboard/<%= guild.id %>/welcome"><i class="fas fa-sign-in-alt"></i> Boas-Vindas</a>
