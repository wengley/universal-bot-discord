        <a class="nav-link <%= activePage === 'member-counter' ? 'active' : '' %>" href="/dashboard/<%= guild.id %>/member-counter"><i class="fas fa-users"></i> Contador de Membros</a>
        <a class="nav-link <%= activePage === 'permissions' ? 'active' : '' %>" href="/dashboard/<%= guild.id %>/permissions"><i class="fas fa-user-shield"></i> Permissões</a>

        <div class="nav-separator">MODERAÇÃO</div>
        <a class="nav-link <%= activePage === 'invite-blocker' ? 'active' : '' %>" href="/dashboard/<%= guild.id %>/invite-blocker"><i class="fas fa-ban"></i> Bloqueador de Convites</a>
        <a class="nav-link <%= activePage === 'punishment-log' ? 'active' : '' %>" href="/dashboard/<%= guild.id %>/punishment-log"><i class="fas fa-gavel"></i> Registro de Punições</a>
        <a class="nav-link <%= activePage === 'warn-actions' ? 'active' : '' %>" href="/dashboard/<%= guild.id %>/warn-actions"><i class="fas fa-exclamation-triangle"></i> Punições de Avisos</a>
        <a class="nav-link <%= activePage === 'event-log' ? 'active' : '' %>" href="/dashboard/<%= guild.id %>/event-log"><i class="fas fa-scroll"></i> Registro de Eventos</a>

