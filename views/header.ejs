<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Universal Bot | <%= (typeof guild !== 'undefined' && guild) ? guild.name : 'Dashboard' %></title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="icon" href="https://cdn.discordapp.com/icons/1419328224730546278/cb6cf837588174754302cd3dfd8f6654.webp?size=4096" type="image/webp">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script>
        function toggleTheme() {
            const next = document.body.classList.contains('light') ? 'dark' : 'light';
            document.body.className = next;
            localStorage.setItem('theme', next);
        }
        document.addEventListener('DOMContentLoaded', () => {
            const saved = localStorage.getItem('theme') || 'dark';
            document.body.className = saved;
        });
        function toggleSidebar(force) {
            const wrapper = document.getElementById('wrapper');
            if (typeof force === 'boolean') wrapper.classList.toggle('sidebar-open', force);
            else wrapper.classList.toggle('sidebar-open');
        }
    </script>
</head>
<body>

<div id="wrapper">
    <div class="mobile-topbar">
        <button class="hamburger-btn" onclick="toggleSidebar()" aria-label="Abrir menu"><i class="fas fa-bars"></i></button>
        <% if (typeof guild !== 'undefined' && guild) { %>
            <img src="<%= guild.iconURL({ size: 64 }) || botAvatarUrl %>" alt="">
            <span><%= guild.name %></span>
        <% } else { %>
            <img src="<%= botAvatarUrl %>" alt="">
            <span>Universal Bot</span>
        <% } %>
    </div>
    <div class="sidebar-backdrop" onclick="toggleSidebar(false)"></div>